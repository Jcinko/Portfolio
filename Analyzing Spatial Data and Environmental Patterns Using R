# 7. ---------- Classified landslide susceptibility map (cut-based) ----------

# Convert raster values into categorical classes using cut()
landslide_class <- raster::calc(landslide_raw, fun = function(x) {
  cut(
    x,
    breaks = c(0, 0.3, 0.7, 1.0),
    include.lowest = TRUE,
    labels = c(
      "0.0–0.3 – Low susceptibility",
      "0.3–0.7 – Moderate susceptibility",
      "0.7–1.0 – High susceptibility"
    )
  )
})

# Convert to factor explicitly for tmap
landslide_class <- as.factor(landslide_class)

# Green → Yellow → Red color scheme
sus_colors <- c("#2ECC71", "#F1C40F", "#E74C3C")  
# (low, moderate, high)

# Build tmap
tm_landslide_class <-
  tm_shape(landslide_class) +
  tm_raster(
    title   = "Landslide Susceptibility Class",
    palette = sus_colors,
    style   = "cat",
    labels  = c(
      "0.0–0.3 – Low susceptibility",
      "0.3–0.7 – Moderate susceptibility",
      "0.7–1.0 – High susceptibility"
    )
  ) +
  tm_shape(st_geometry(county_sf)) +
  tm_borders(col = "black", lwd = 0.6) +
  # Add county boundaries to the legend WITHOUT a title
  tm_add_legend(
