# 13. ---------- Build spatial weights matrix (Queen contiguity) ----------

# Install/load spdep for spatial autocorrelation analysis
if (!"spdep" %in% installed.packages()[, "Package"]) {
  install.packages("spdep", quiet = TRUE)
}
library(spdep)

# Convert sf to Spatial for spdep
county_sp <- as(county_sf_stats, "Spatial")

# Create neighbors list (Queen contiguity)
nb_queen <- poly2nb(county_sp, queen = TRUE)

# Convert neighbors to row-standardized spatial weights
lw_queen <- nb2listw(nb_queen, style = "W", zero.policy = TRUE)
cat("Step 13 complete: Queen contiguity neighbors and weights matrix built.\n")



# 14. ---------- Global Moran's I for percent high-risk ----------

# Ensure variable exists
if (!"pct_high_risk" %in% names(county_sf_stats)) {
  stop("Step 14 error: 'pct_high_risk' not found in county_sf_stats. 
       Make sure Step 10 completed successfully.")
}
moran_result <- moran.test(
  county_sf_stats$pct_high_risk,
  lw_queen,
  zero.policy = TRUE
)
print(moran_result)

# Save Moran's I summary to a text file
moran_out_path <- file.path(tables_dir, "Global_MoransI_pctHighRisk.txt")
sink(moran_out_path)
print(moran_result)
sink()
cat("Step 14 complete: Global Moran's I calculated and saved to:\n",
    moran_out_path, "\n")



# 15. ---------- Local Moran's I (LISA) for percent high-risk ----------

local_moran <- localmoran(
  county_sf_stats$pct_high_risk,
  lw_queen,
  zero.policy = TRUE
)

# Attach LISA stats to county_sf_stats
county_sf_stats$local_I      <- local_moran[, 1]  # Local Moran's I
county_sf_stats$local_pvalue <- local_moran[, 5]  # p-value

# Initialize cluster type
county_sf_stats$cluster_type <- NA_character_

# Use overall mean to distinguish "high" vs "low" % high-risk
mean_val <- mean(county_sf_stats$pct_high_risk, na.rm = TRUE)
high_val <- county_sf_stats$pct_high_risk > mean_val
I_pos    <- county_sf_stats$local_I > 0

# High–High (hot spot)
county_sf_stats$cluster_type[
  high_val & I_pos & county_sf_stats$local_pvalue < 0.05
] <- "High–High (Hot Spot)"

# Low–Low (cold spot)
county_sf_stats$cluster_type[
  (!high_val) & I_pos & county_sf_stats$local_pvalue < 0.05
] <- "Low–Low (Cold Spot)"

# High–Low outlier
county_sf_stats$cluster_type[
  high_val & (!I_pos) & county_sf_stats$local_pvalue < 0.05
] <- "High–Low Outlier"

# Low–High outlier
county_sf_stats$cluster_type[
  (!high_val) & (!I_pos) & county_sf_stats$local_pvalue < 0.05
] <- "Low–High Outlier"

# Non-significant
county_sf_stats$cluster_type[
  is.na(county_sf_stats$cluster_type)
] <- "Not Significant"

# Make it a factor with a nice ordering
cluster_levels <- c(
  "High–High (Hot Spot)",
  "Low–Low (Cold Spot)",
  "High–Low Outlier",
  "Low–High Outlier",
  "Not Significant"
)
county_sf_stats$cluster_type <- factor(
  county_sf_stats$cluster_type,
  levels = cluster_levels
)

# Save LISA results to CSV
lisa_out_path <- file.path(tables_dir, "County_LISA_Results_pctHighRisk.csv")
lisa_df <- st_drop_geometry(county_sf_stats)[, c(
  "ID",
  "county_name",
  "pct_high_risk",
  "local_I",
  "local_pvalue",
  "cluster_type"
)]
write.csv(lisa_df, lisa_out_path, row.names = FALSE)
cat("Step 15 complete: Local Moran's I computed and LISA results saved to:\n",
    lisa_out_path, "\n")



