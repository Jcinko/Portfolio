# 3. ---------- Define Input File Paths of Raw Data ----------

# Updated input raster + vector paths
landslide_path <- file.path(
  processed_dir,
  "Landslide_30m.tif"
)
county_path <- file.path(
  raw_dir,
  "WV_county_boundaries_24k_topo_updated_2022_utm83.shp"
)
cat("Step 3 complete: Input file paths defined.\n")



# 4. ---------- Read landslide raster & county boundary ----------

# Read the resampled landslide raster
landslide_raw <- raster(landslide_path)

