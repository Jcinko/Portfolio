# 5. ---------- Ensure raster and county share the same CRS ----------

crs_rast <- crs(landslide_raw)
crs_vect <- st_crs(county_sf)
if (crs_vect$proj4string != crs_rast@projargs) {
  county_sf <- st_transform(county_sf, crs = crs_rast@projargs)
  cat("County CRS transformed to match raster CRS.\n")
} else {
  cat("CRS already matched between raster and county.\n")
}
cat("Step 5 complete: CRS aligned between raster and county.\n")



