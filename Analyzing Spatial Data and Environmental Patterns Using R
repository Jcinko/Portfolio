# 10. ---------- County-level landslide statistics ----------

# Add an ID field to counties to keep everything aligned
county_sf$ID <- 1:nrow(county_sf)

# Use the existing county name field
name_field <- "County_Nam"

# A. Continuous susceptibility per county (30 m raster)
sus_df <- raster::extract(
  landslide_raw,   # 30 m raster
  county_sf,
  df = TRUE
)

# Rename the value column to a standard name ("value")
# Column 1 is "ID", column 2 is the raster values
colnames(sus_df)[2] <- "value"

sus_summary <- sus_df |>
  dplyr::group_by(ID) |>
  dplyr::summarise(
    mean_susc   = mean(value, na.rm = TRUE),
    median_susc = stats::median(value, na.rm = TRUE),
    sd_susc     = stats::sd(value, na.rm = TRUE),
    n_cells     = sum(!is.na(value)),
    .groups     = "drop"
  )

# B. High-risk (binary) per county
hr_df <- raster::extract(
  landslide_highrisk,
  county_sf,
  df = TRUE
)

# Again, standardize the value column name
colnames(hr_df)[2] <- "value"
hr_summary <- hr_df |>
  dplyr::group_by(ID) |>
  dplyr::summarise(
    total_cells   = sum(!is.na(value)),
    high_cells    = sum(value == 1, na.rm = TRUE),
    pct_high_risk = ifelse(total_cells > 0,
                           high_cells / total_cells * 100, NA_real_),
    .groups       = "drop"
  )

# Cell area and high-risk area (km²)
cell_area_m2   <- prod(res(landslide_highrisk))
hr_summary$area_high_risk_km2 <- hr_summary$high_cells * cell_area_m2 / 1e6
hr_summary$area_total_km2     <- hr_summary$total_cells * cell_area_m2 / 1e6

# C. Combine summaries & add county names
county_stats <- sus_summary |>
  dplyr::left_join(hr_summary, by = "ID") |>
  dplyr::mutate(
    county_name = county_sf[[name_field]][ID]
  ) |>
  dplyr::select(
    ID,
    county_name,
    mean_susc,
    median_susc,
    sd_susc,
    n_cells,
    total_cells,
    high_cells,
    pct_high_risk,
    area_high_risk_km2,
    area_total_km2
  )

# Add rank fields (higher rank = more high-risk)
county_stats <- county_stats |>
  dplyr::arrange(dplyr::desc(pct_high_risk)) |>
  dplyr::mutate(
    rank_pct_high  = dplyr::row_number(),
    rank_mean_susc = dplyr::dense_rank(dplyr::desc(mean_susc))
  )

# D. Save table & join back to sf
county_table_path <- file.path(tables_dir, "County_Landslide_Summary.csv")
write.csv(county_stats, county_table_path, row.names = FALSE)
county_sf_stats <- county_sf |>
  dplyr::left_join(county_stats, by = "ID")
