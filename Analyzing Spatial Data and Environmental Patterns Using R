# 1. ---------- Project setup & directory definitions ---------- 

# Set working directory (update path as needed)
setwd("your/project/directory")
cat("Working directory set to:", getwd(), "\n")

# Define project folders
raw_dir       <- file.path(getwd(), "Data_Raw")
processed_dir <- file.path(getwd(), "Data_Processed")
figures_dir   <- file.path(getwd(), "Outputs_Figures")
tables_dir    <- file.path(getwd(), "Outputs_Tables")

# Create directories if they do not already exist
dirs_to_make <- c(raw_dir, processed_dir, figures_dir, tables_dir)
for (d in dirs_to_make) {
  if (!dir.exists(d)) {
    dir.create(d, recursive = TRUE)
    cat("Created missing directory:", d, "\n")
  } else {
    cat("Directory already exists:", d, "\n")
  }
}
cat("Step 1 complete: All project directories ready.\n")



# 2. ---------- Load Packages and Libraries ----------

# Define all required packages
required_packages <- c("sf", "raster", "tmap", "dplyr", "terra")

# Install missing packages automatically
missing <- required_packages[!(required_packages %in% installed.packages()[, "Package"])]
if (length(missing) > 0) {
  install.packages(missing, quiet = TRUE)
}

# Load all packages in one clean step
invisible(lapply(required_packages, library, character.only = TRUE))

# Set tmap mode and confirm step completion
tmap_mode("plot")
