# 8. ---------- Define high-risk threshold & create binary mask ----------

# High-risk definition: 0.7–1.0 = high susceptibility
high_risk_threshold <- 0.7

# Create a binary raster:
# 1 = high-risk pixel (>= 0.7)
# 0 = not high-risk (< 0.7)
landslide_highrisk <- raster::calc(landslide_raw, fun = function(x) {
  out <- rep(NA_real_, length(x))
  out[!is.na(x) & x >= high_risk_threshold] <- 1
  out[!is.na(x) & x <  high_risk_threshold] <- 0
  out
})

# Save high-risk mask raster
highrisk_path <- file.path(processed_dir, "Landslide_HighRiskMask_30m.tif")
writeRaster(landslide_highrisk, highrisk_path, overwrite = TRUE)

# Overall WV high-risk summary
hr_vals <- raster::values(landslide_highrisk)
hr_vals <- hr_vals[!is.na(hr_vals)]
total_cells <- length(hr_vals)
high_cells  <- sum(hr_vals == 1)
pct_high    <- high_cells / total_cells * 100

# Cell area (m^2) and area in km^2 (30 m * 30 m = 900 m²)
cell_area_m2      <- prod(res(landslide_highrisk))
area_high_km2     <- high_cells  * cell_area_m2 / 1e6
area_total_km2    <- total_cells * cell_area_m2 / 1e6

# Save summary to CSV
wv_hr_summary <- data.frame(
  metric = c(
    "total_cells",
    "high_risk_cells",
    "percent_high_risk",
    "area_high_risk_km2",
    "area_total_km2"
  ),
  value = c(
    total_cells,
    high_cells,
    pct_high,
    area_high_km2,
    area_total_km2
  )
)
hr_summary_path <- file.path(tables_dir, "WV_HighRiskSummary.csv")
write.csv(wv_hr_summary, hr_summary_path, row.names = FALSE)
cat("Step 8 complete: High-risk mask raster saved and WV summary written to:\n",
    highrisk_path, "\n",
    hr_summary_path, "\n")



