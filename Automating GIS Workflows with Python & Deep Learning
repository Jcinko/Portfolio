# --- Step 1: Setup Environment and Get Tool Parameters ---
# This block sets up the script environment, fetches user-provided parameters,
# and creates directories and helper functions for the workflow.

import arcpy
from arcpy.sa import *
import os
import shutil
import time
import warnings
from datetime import datetime

# Suppress optional PRF method/property warnings
warnings.filterwarnings("ignore", message="Missing \(optional\) PRF Method/Property", category=UserWarning)

# Check out Spatial Analyst extension
arcpy.CheckOutExtension("Spatial")

# Get parameters from script tool
input_dir = arcpy.GetParameterAsText(0)  # Input Folder
output_dir = arcpy.GetParameterAsText(1)  # Output Folder
model_full_path = arcpy.GetParameterAsText(2)  # .dlpk Model File
spatial_ref = arcpy.GetParameter(3)  # Spatial Reference
resample_cell_size = arcpy.GetParameterAsText(4)  # e.g., "0.2 0.2"
buffer_distance = arcpy.GetParameterAsText(5)  # e.g., "0.5 Feet"
filename_base = arcpy.GetParameterAsText(6)  # e.g., "Final_Project_Buildings"

today_str = datetime.today().strftime("%Y%m%d")

# Create required folders
preprocessing_dir = os.path.join(output_dir, "Preprocessing")
detected_dir = os.path.join(output_dir, "Detected_AI_Objects")
pre_merged_dir = os.path.join(detected_dir, "Pre_Merged_Shapefiles")
final_output_dir = os.path.join(output_dir, "Final_Project_Output")
os.makedirs(preprocessing_dir, exist_ok=True)
os.makedirs(detected_dir, exist_ok=True)
os.makedirs(pre_merged_dir, exist_ok=True)
os.makedirs(final_output_dir, exist_ok=True)

# Setup logging
log_file_path = os.path.join(final_output_dir, f"Workflow_Log_{today_str}.txt")
log_file = open(log_file_path, "w", encoding="utf-8")

def log_message(msg):
    print(msg)
    log_file.write(msg + "\n")

def format_time(seconds):
    return f"{int(seconds // 60)} min {int(seconds % 60)} sec"

start_total = time.time()

# --- Step 2: Preprocessing Imagery ---
log_message("\n🔧 Step 1: Preprocessing Imagery")
supported_extensions = [".tif", ".tiff", ".img", ".jpg", ".jpeg", ".jp2", ".bmp", ".png"]
raster_files = [f for f in os.listdir(input_dir) if os.path.splitext(f)[1].lower() in supported_extensions]

image_count = 0
step1_start = time.time()
for file in raster_files:
    file_path = os.path.join(input_dir, file)
    try:
        start = time.time()
        raster_obj = arcpy.Raster(file_path)
        if raster_obj.bandCount != 3:
            log_message(f"⏩ Skipping {file} — not RGB")
            continue
        image_count += 1
        base = os.path.splitext(file)[0]
        final_name = f"{base}_Preprocessed_{today_str}.tif"
        resampled_path = os.path.join(preprocessing_dir, final_name)
        temp_8bit = os.path.join(preprocessing_dir, f"{base}_8bit_temp.tif")

        if raster_obj.pixelType not in ["U8", "8_BIT_UNSIGNED"]:
            arcpy.management.CopyRaster(file_path, temp_8bit, pixel_type="8_BIT_UNSIGNED", format="TIFF")
            input_for_resample = temp_8bit
        else:
            input_for_resample = file_path

        arcpy.management.Resample(input_for_resample, resampled_path, cell_size=resample_cell_size, resampling_type="BILINEAR")
        arcpy.management.DefineProjection(resampled_path, spatial_ref)
        elapsed = time.time() - start
        log_message(f"✅ Preprocessed: {file} ({format_time(elapsed)})")

    except Exception as e:
        log_message(f"❌ Failed {file}: {e}")
log_message(f"🕒 Step 1 completed in {format_time(time.time() - step1_start)}")

# --- Step 3: Deep Learning Detection ---
log_message("\n🧠 Step 2: Object Detection")
tif_files = [f for f in os.listdir(preprocessing_dir) if f.lower().endswith(".tif")]

detection_start = time.time()
for tif_file in tif_files:
    try:
        start = time.time()
        base = os.path.splitext(tif_file)[0]
        output_fc = os.path.join(detected_dir, f"Detected_{base}.shp")
        arcpy.ia.DetectObjectsUsingDeepLearning(
            in_raster=os.path.join(preprocessing_dir, tif_file),
            out_detected_objects=output_fc,
            in_model_definition=model_full_path,
            arguments="padding 128;batch_size 4;threshold 0.9;return_bboxes False;test_time_augmentation False;merge_policy mean;tile_size 512",
            run_nms="NO_NMS",
            confidence_score_field="Confidence",
            class_value_field="Class",
            max_overlap_ratio=0,
            processing_mode="PROCESS_AS_MOSAICKED_IMAGE",
            use_pixelspace="NO_PIXELSPACE"
        )
        elapsed = time.time() - start
        log_message(f"✅ Detected buildings in: {tif_file} ({format_time(elapsed)})")
    except Exception as e:
        log_message(f"❌ Detection failed for {tif_file}: {e}")
log_message(f"🕒 Step 2 completed in {format_time(time.time() - detection_start)}")

# --- Step 4: Merge Detected Shapefiles ---
log_message("\n🧹 Step 3: Merging Detected Shapefiles")
step3_start = time.time()
combined_shapefile = os.path.join(detected_dir, f"Combined_Detected_Buildings_{today_str}.shp")
shapefiles = [os.path.join(detected_dir, f) for f in os.listdir(detected_dir) if f.lower().endswith(".shp")]

if len(shapefiles) == 0:
    log_message("❌ No detected shapefiles found. Cannot continue.")
    log_file.close()
    raise RuntimeError("No shapefiles available for merging.")
elif len(shapefiles) == 1:
    log_message("ℹ️ Only one shapefile found. Copying as combined shapefile.")
    base = os.path.splitext(shapefiles[0])[0]
    for ext in [".shp", ".shx", ".dbf", ".prj", ".cpg", ".sbx", ".sbn", ".xml"]:
        src = base + ext
        dst = os.path.join(detected_dir, os.path.basename(src).replace(os.path.basename(base), f"Combined_Detected_Buildings_{today_str}"))
        if os.path.exists(src):
            shutil.copy(src, dst)
    log_message(f"✅ Single shapefile copied as: {combined_shapefile}")
else:
    log_message(f"🔎 Found {len(shapefiles)} shapefile(s) to merge...")
    arcpy.management.Merge(shapefiles, combined_shapefile)
    for shp in shapefiles:
        base = os.path.splitext(shp)[0]
        for ext in [".shp", ".shx", ".dbf", ".prj", ".cpg", ".sbx", ".sbn", ".xml"]:
            path = base + ext
            if os.path.exists(path):
                shutil.move(path, os.path.join(pre_merged_dir, os.path.basename(path)))
    log_message(f"✅ Merged into: {combined_shapefile}")
log_message(f"🕒 Step 3 completed in {format_time(time.time() - step3_start)}")

# --- Step 5: Regularization ---
log_message("\n🛌 Step 4: Regularizing Merged Buildings")
step4_start = time.time()
regularized_output = os.path.join(detected_dir, f"Regularized_Detected_Buildings_{today_str}.shp")

if not arcpy.Exists(combined_shapefile):
    log_message("❌ Combined shapefile not found. Aborting regularization.")
    log_file.close()
    raise FileNotFoundError(f"Combined shapefile does not exist: {combined_shapefile}")

arcpy.management.RepairGeometry(combined_shapefile)
log_message("✅ Geometry repaired.")

arcpy.ddd.RegularizeBuildingFootprint(
    in_features=combined_shapefile,
    out_feature_class=regularized_output,
    method="RIGHT_ANGLES",
    tolerance=1,
    precision=0.25,
    diagonal_penalty=1.5,
    min_radius=0.1,
    max_radius=1000000,
    tolerance_type="DISTANCE"
)
log_message(f"✅ Regularized: {regularized_output}")
log_message(f"🕒 Step 4 completed in {format_time(time.time() - step4_start)}")

# --- Step 6A: Buffering ---
log_message("\n🌀 Step 5: Buffering Regularized Buildings")
step5_start = time.time()
buffered_output = os.path.join(detected_dir, f"Buffered_Detected_Buildings_{today_str}.shp")

arcpy.analysis.Buffer(
    in_features=regularized_output,
    out_feature_class=buffered_output,
    buffer_distance_or_field=buffer_distance,
    line_side="FULL",
    line_end_type="ROUND",
    dissolve_option="NONE",
    method="PLANAR"
)
log_message(f"✅ Buffered: {buffered_output}")
log_message(f"🕒 Step 5 completed in {format_time(time.time() - step5_start)}")

# --- Step 6B: Final Regularization ---
log_message("\n🌟 Step 6: Final Building Regularization")
step6_start = time.time()
final_output = os.path.join(final_output_dir, f"{filename_base}_{today_str}.shp")

arcpy.ddd.RegularizeBuildingFootprint(
    in_features=buffered_output,
    out_feature_class=final_output,
    method="RIGHT_ANGLES",
    tolerance=0.5,
    precision=0.25,
    diagonal_penalty=1.5,
    min_radius=0.1,
    max_radius=1000000,
    tolerance_type="DISTANCE"
)
log_message(f"✅ Final buildings shapefile: {final_output}")
log_message(f"🕒 Step 6 completed in {format_time(time.time() - step6_start)}")

# --- Wrap-up: Summary and Metrics ---
final_feature_count = int(arcpy.management.GetCount(final_output)[0])
total_runtime_sec = time.time() - start_total
total_runtime = format_time(total_runtime_sec)
rate = round(final_feature_count / (total_runtime_sec / 60), 2) if total_runtime_sec > 0 else 0

log_message("\n🎉 Workflow complete!")
log_message(f"📸 Images processed: {image_count}")
log_message(f"🏢 Total buildings in final output: {final_feature_count}")
log_message(f"⏱️ Total runtime: {total_runtime}")
log_message(f"📊 Rate: {rate} buildings generated per minute")

log_file.close()
